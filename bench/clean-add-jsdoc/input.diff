diff --git a/src/util/clamp.ts b/src/util/clamp.ts
--- a/src/util/clamp.ts
+++ b/src/util/clamp.ts
@@ -1,3 +1,6 @@
+/**
+ * Constrain `value` to the inclusive [min, max] range.
+ */
 export function clamp(value: number, min: number, max: number): number {
   return Math.min(Math.max(value, min), max);
 }
